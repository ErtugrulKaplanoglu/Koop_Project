@model KooperatifYonetim.Core.Entities.EkinTuru
@{
    ViewData["Title"] = "Ekin Türü Ekle";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">Yeni Ekin Türü</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Ad" class="form-label fw-semibold">Ad</label>
                        <input asp-for="Ad" class="form-control" placeholder="Örn: Domates" />
                        <span asp-validation-for="Ad" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ToplamaTipi" class="form-label fw-semibold">Toplama Tipi</label>
                        <select asp-for="ToplamaTipi" asp-items="Html.GetEnumSelectList<KooperatifYonetim.Core.Enums.ToplamaTipi>()" class="form-select"></select>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-save me-1"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
