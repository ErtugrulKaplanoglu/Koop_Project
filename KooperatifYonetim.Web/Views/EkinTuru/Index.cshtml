@model IEnumerable<KooperatifYonetim.Core.Entities.EkinTuru>
@{
    ViewData["Title"] = "Ekin Türleri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Ekin Türleri</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Yeni Ekin Türü
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Ad</th>
                        <th>Toplama Tipi</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var et in Model)
                    {
                        <tr class="@(et.AktifMi ? "" : "table-secondary text-muted")">
                            <td class="fw-semibold">@et.Ad</td>
                            <td>
                                @if (et.ToplamaTipi == KooperatifYonetim.Core.Enums.ToplamaTipi.Periyodik)
                                {
                                    <span class="badge bg-success">Periyodik</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Tek Hasat</span>
                                }
                            </td>
                            <td>
                                @if (et.AktifMi)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@et.EkinTuruId" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleAktif" asp-route-id="@et.EkinTuruId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(et.AktifMi ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(et.AktifMi ? "Pasife Al" : "Aktife Al")">
                                        <i class="bi @(et.AktifMi ? "bi-pause-circle" : "bi-play-circle")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
