@model IEnumerable<KooperatifYonetim.Core.Entities.TarimHastalikBildirimi>
@{
    ViewData["Title"] = "Tarım Hastalık Bildirimleri";
    var isMuhendis = User.IsInRole("ZiraatMuhendisi") || User.IsInRole("Yonetici");
    var canCreate = User.IsInRole("Yonetici") || User.IsInRole("Uretici");
    var bekleyenSayisi = Model.Count(b => b.Durum == KooperatifYonetim.Core.Enums.BildirimDurum.Beklemede);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Tarım Hastalık Bildirimleri</h4>
        <p class="text-muted small mb-0">
            @Model.Count() bildirim
            @if (bekleyenSayisi > 0)
            {
                <span class="badge bg-danger ms-1">@bekleyenSayisi bekliyor</span>
            }
        </p>
    </div>
    @if (canCreate)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Bildirim Oluştur
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-bug fs-1 d-block mb-2"></i>
                @if (isMuhendis)
                {
                    <span>Size atanmış hastalık bildirimi bulunmuyor.</span>
                }
                else
                {
                    <span>Henüz hastalık bildirimi oluşturulmamış.</span>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Ekin</th>
                            <th>Arazi</th>
                            <th>Bildirim Tarihi</th>
                            <th>Açıklama</th>
                            @if (isMuhendis)
                            {
                                <th>Üretici</th>
                            }
                            <th>Mühendis</th>
                            <th>Durum</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@b.Ekin?.EkinTuru</td>
                                <td>@b.Ekin?.Arazi?.Ad</td>
                                <td>@b.BildirimTarihi.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <span title="@b.Aciklama">
                                        @(b.Aciklama.Length > 60 ? b.Aciklama[..60] + "…" : b.Aciklama)
                                    </span>
                                </td>
                                @if (isMuhendis)
                                {
                                    <td>@b.Uretici?.Ad @b.Uretici?.Soyad</td>
                                }
                                <td>
                                    @if (b.Muhendis is not null)
                                    {
                                        <span>@b.Muhendis.Ad @b.Muhendis.Soyad</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Atanmadı</span>
                                    }
                                </td>
                                <td>
                                    @switch (b.Durum)
                                    {
                                        case KooperatifYonetim.Core.Enums.BildirimDurum.Beklemede:
                                            <span class="badge bg-warning text-dark">Beklemede</span>
                                            break;
                                        case KooperatifYonetim.Core.Enums.BildirimDurum.Inceleniyor:
                                            <span class="badge bg-primary">İnceleniyor</span>
                                            break;
                                        case KooperatifYonetim.Core.Enums.BildirimDurum.Cozuldu:
                                            <span class="badge bg-success">Çözüldü</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    @if (isMuhendis && b.Durum != KooperatifYonetim.Core.Enums.BildirimDurum.Cozuldu)
                                    {
                                        <a asp-action="DurumGuncelle" asp-route-id="@b.BildirimId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-arrow-repeat me-1"></i>Güncelle
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
