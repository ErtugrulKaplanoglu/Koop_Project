@model IEnumerable<KooperatifYonetim.Web.Models.KullaniciListeViewModel>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Kullanıcı Yönetimi</h4>
        <p class="text-muted small mb-0">@Model.Count() kayıtlı kullanıcı</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Yeni Kullanıcı
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Telefon</th>
                        <th>Rol</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@u.Ad @u.Soyad</td>
                            <td class="text-muted small">@u.Email</td>
                            <td class="text-muted small">@(u.Telefon ?? "—")</td>
                            <td>
                                @{
                                    var badgeClass = u.Rol switch
                                    {
                                        "Yonetici" => "bg-danger",
                                        "Uretici" => "bg-success",
                                        "ZiraatMuhendisi" => "bg-primary",
                                        "Veteriner" => "bg-info text-dark",
                                        "Mandira" => "bg-secondary",
                                        "Toptanci" => "bg-warning text-dark",
                                        "Tedarikci" => "bg-dark",
                                        _ => "bg-light text-dark"
                                    };
                                    var rolGoster = u.Rol switch
                                    {
                                        "ZiraatMuhendisi" => "Ziraat Müh.",
                                        "Yonetici" => "Yönetici",
                                        "Uretici" => "Üretici",
                                        "Mandira" => "Mandıra",
                                        "Toptanci" => "Toptancı",
                                        "Tedarikci" => "Tedarikçi",
                                        _ => u.Rol
                                    };
                                }
                                <span class="badge @badgeClass">@rolGoster</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil me-1"></i>Düzenle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
