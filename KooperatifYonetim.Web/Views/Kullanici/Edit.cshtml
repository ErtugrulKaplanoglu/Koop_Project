@model KooperatifYonetim.Web.Models.KullaniciFormViewModel
@{
    ViewData["Title"] = "Kullanıcı Düzenle";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">Kullanıcı Düzenle</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="MevcutRol" type="hidden" />

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="Ad" class="form-label fw-semibold"></label>
                            <input asp-for="Ad" class="form-control" />
                            <span asp-validation-for="Ad" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Soyad" class="form-label fw-semibold"></label>
                            <input asp-for="Soyad" class="form-control" />
                            <span asp-validation-for="Soyad" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefon" class="form-label fw-semibold"></label>
                        <input asp-for="Telefon" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Rol" class="form-label fw-semibold"></label>
                        <select asp-for="Rol" asp-items="Model.RolListesi" class="form-select"></select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Sifre" class="form-label fw-semibold"></label>
                        <input asp-for="Sifre" type="password" class="form-control"
                               placeholder="Değiştirmek istemiyorsanız boş bırakın" />
                        <div class="form-text">Boş bırakırsanız mevcut şifre değişmez.</div>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-check-circle me-1"></i> Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
