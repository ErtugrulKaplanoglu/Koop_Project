@model IEnumerable<KooperatifYonetim.Core.Entities.UrunTemin>
@{
    ViewData["Title"] = "Ürün Teminleri";
    var canCreate = User.IsInRole("Yonetici") || User.IsInRole("Toptanci");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Ürün Teminleri</h4>
        <p class="text-muted small mb-0">Toplam @Model.Count() kayıt</p>
    </div>
    @if (canCreate)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Yeni Temin
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-box-seam fs-1 d-block mb-2"></i>
                Henüz ürün temin kaydı bulunmuyor.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Arazi</th>
                            <th>Toptancı</th>
                            <th>Dönem</th>
                            <th>Planlanan (kg)</th>
                            <th>Alınan (kg)</th>
                            <th>Tamamlanma</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var temin in Model)
                        {
                            var yuzde = temin.AlinanMiktar.HasValue && temin.PlanlananMiktar > 0
                                ? (int)((temin.AlinanMiktar.Value / temin.PlanlananMiktar) * 100)
                                : 0;
                            <tr>
                                <td>
                                    <a asp-controller="Arazi" asp-action="Details" asp-route-id="@temin.AraziId" class="text-decoration-none fw-semibold">
                                        @temin.Arazi?.Ad
                                    </a>
                                </td>
                                <td>@temin.Toptanci?.Ad @temin.Toptanci?.Soyad</td>
                                <td><span class="badge bg-primary-subtle text-primary">@temin.Donem</span></td>
                                <td>@temin.PlanlananMiktar.ToString("N0")</td>
                                <td>@(temin.AlinanMiktar.HasValue ? temin.AlinanMiktar.Value.ToString("N0") : "—")</td>
                                <td style="min-width:120px">
                                    @if (temin.AlinanMiktar.HasValue)
                                    {
                                        <div class="progress" style="height:8px">
                                            <div class="progress-bar @(yuzde >= 100 ? "bg-success" : "bg-warning")"
                                                 style="width:@(Math.Min(yuzde,100))%"></div>
                                        </div>
                                        <small class="text-muted">%@yuzde</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (canCreate)
                                    {
                                        <a asp-action="Edit" asp-route-id="@temin.UrunTeminId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@temin.UrunTeminId" method="post" class="d-inline ms-1"
                                              onsubmit="return confirm('Bu temin kaydını silmek istediğinizden emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
