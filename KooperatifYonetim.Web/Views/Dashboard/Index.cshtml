@model KooperatifYonetim.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var rolAdi = User.IsInRole("Yonetici") ? "Yönetici" :
                 User.IsInRole("Uretici") ? "Üretici" :
                 User.IsInRole("ZiraatMuhendisi") ? "Ziraat Mühendisi" :
                 User.IsInRole("Veteriner") ? "Veteriner" :
                 User.IsInRole("Toptanci") ? "Toptancı" :
                 User.IsInRole("Mandira") ? "Mandıra" :
                 User.IsInRole("Tedarikci") ? "Tedarikçi" : "Kullanıcı";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Dashboard</h4>
        <p class="text-muted mb-0 small">Hoş geldiniz, <strong>@User.Identity?.Name</strong> — @rolAdi</p>
    </div>
</div>

@if (User.IsInRole("Yonetici"))
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-map text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.ToplamArazi</div>
                            <div class="text-muted small">Toplam Arazi</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-house text-primary fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.ToplamAhir</div>
                            <div class="text-muted small">Toplam Ahır</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-warning-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-people text-warning fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.ToplamKullanici</div>
                            <div class="text-muted small">Kullanıcılar</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-danger-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@(Model.AcikTarimBildirim + Model.AcikHayvanBildirim)</div>
                            <div class="text-muted small">Açık Bildirimler</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <h6 class="fw-bold mb-0"><i class="bi bi-lightning me-2 text-warning"></i>Hızlı Erişim</h6>
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-6 col-md-3">
                    <a asp-controller="Kullanici" asp-action="Index" class="btn btn-outline-secondary w-100 text-start">
                        <i class="bi bi-people me-2"></i> Kullanıcılar
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="Arazi" asp-action="Index" class="btn btn-outline-success w-100 text-start">
                        <i class="bi bi-map me-2"></i> Tüm Araziler
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="Ahir" asp-action="Index" class="btn btn-outline-primary w-100 text-start">
                        <i class="bi bi-house me-2"></i> Tüm Ahırlar
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="TarimHastalik" asp-action="Index" class="btn btn-outline-danger w-100 text-start">
                        <i class="bi bi-bug me-2"></i> Hastalık Bildirimleri
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else if (User.IsInRole("Uretici"))
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-map text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.AraziSayisi</div>
                            <div class="text-muted small">Arazilerim</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-house text-primary fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.AhirSayisi</div>
                            <div class="text-muted small">Ahırlarım</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-warning-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-calendar-check text-warning fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.BuHaftaIslem</div>
                            <div class="text-muted small">Bu Hafta İşlemler</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-danger-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-bug text-danger fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.AcikBildirim</div>
                            <div class="text-muted small">Açık Bildirimler</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @if (Model.YaklasanIslemler.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-calendar-week me-2 text-warning"></i>Bu Hafta Yaklaşan İşlemler</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead><tr><th>Tarih</th><th>Ekin</th><th>Arazi</th><th>İşlem</th></tr></thead>
                    <tbody>
                        @foreach (var islem in Model.YaklasanIslemler)
                        {
                            <tr>
                                <td>@islem.PlanlananTarih.ToString("dd.MM.yyyy")</td>
                                <td class="fw-semibold">@islem.EkinTuru</td>
                                <td class="text-muted small">@islem.AraziAdi</td>
                                <td>
                                    @switch (islem.IslemTuru)
                                    {
                                        case "Sulama":
                                            <span class="badge bg-info text-dark">Sulama</span>
                                            break;
                                        case "Ilacalama":
                                            <span class="badge bg-warning text-dark">İlaçlama</span>
                                            break;
                                        case "Toplama":
                                            <span class="badge bg-success">Toplama</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@islem.IslemTuru</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-4">
                <i class="bi bi-calendar-check fs-2 d-block mb-2 text-success"></i>
                Bu hafta planlı işlem bulunmuyor.
            </div>
        </div>
    }
}
else if (User.IsInRole("ZiraatMuhendisi"))
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-warning-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-hourglass text-warning fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.BekleyenBildirim</div>
                            <div class="text-muted small">Bekleyen</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-search text-primary fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.InceleniyorBildirim</div>
                            <div class="text-muted small">İnceleniyor</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-check-circle text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.CozulduBildirim</div>
                            <div class="text-muted small">Çözüldü</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-3">
            <a asp-controller="TarimHastalik" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-bug me-2"></i>Hastalık Bildirimlerini Görüntüle
            </a>
        </div>
    </div>
}
else if (User.IsInRole("Veteriner"))
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-calendar2-heart text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.YaklasanBakim</div>
                            <div class="text-muted small">Bu Hafta Bakım</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-danger-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-exclamation-circle text-danger fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.GecikmiBakim</div>
                            <div class="text-muted small">Gecikmiş Bakım</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-warning-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-heart-pulse text-warning fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.AcikHayvanHastalik</div>
                            <div class="text-muted small">Açık Bildirimler</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-body d-flex gap-2 flex-wrap">
            <a asp-controller="VeterinerBakim" asp-action="Index" class="btn btn-outline-success">
                <i class="bi bi-calendar2-heart me-2"></i>Bakım Takvimine Git
            </a>
            <a asp-controller="HayvanHastalik" asp-action="Index" class="btn btn-outline-danger">
                <i class="bi bi-heart-pulse me-2"></i>Hastalık Bildirimleri
            </a>
        </div>
    </div>
}
else if (User.IsInRole("Mandira"))
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-6">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-info-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-droplet text-info fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.BuHaftaSut.ToString("N1") L</div>
                            <div class="text-muted small">Bu Hafta Toplam</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-6">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-droplet-half text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.BuAySut.ToString("N1") L</div>
                            <div class="text-muted small">Bu Ay Toplam</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <h6 class="fw-bold mb-0"><i class="bi bi-bar-chart me-2 text-info"></i>Son 7 Gün Süt Üretimi</h6>
        </div>
        <div class="card-body">
            <canvas id="sutGrafik" height="100"></canvas>
        </div>
    </div>

}
else if (User.IsInRole("Toptanci"))
{
    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-box-seam text-primary fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.AktifTemin</div>
                            <div class="text-muted small">Aktif Temin</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-boxes text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.ToplamPlanlananMiktar.ToString("N0") kg</div>
                            <div class="text-muted small">Planlanan Miktar</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <a asp-controller="UrunTemin" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-box-seam me-2"></i>Temin Listesine Git
            </a>
        </div>
    </div>
}
else if (User.IsInRole("Tedarikci"))
{
    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-archive text-primary fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.ToplamStok</div>
                            <div class="text-muted small">Toplam Stok Kaydı</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card koop-stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-danger-subtle rounded-3 p-3 me-3">
                            <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-4">@Model.KritikStok</div>
                            <div class="text-muted small">Kritik Seviye</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <a asp-controller="BesiStok" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-archive me-2"></i>Stok Durumlarına Git
            </a>
        </div>
    </div>
}
else
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        Sisteme başarıyla giriş yaptınız. Sol menüden işlemlerinize devam edebilirsiniz.
    </div>
}

@if (User.IsInRole("Mandira"))
{
    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script>
            const gunler = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HaftalikSutGrafik.Select(g => g.Gun)));
            const miktarlar = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HaftalikSutGrafik.Select(g => g.Miktar)));
            new Chart(document.getElementById('sutGrafik'), {
                type: 'bar',
                data: {
                    labels: gunler,
                    datasets: [{
                        label: 'Süt (L)',
                        data: miktarlar,
                        backgroundColor: 'rgba(13,202,240,0.6)',
                        borderColor: 'rgba(13,202,240,1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        </script>
    }
}
