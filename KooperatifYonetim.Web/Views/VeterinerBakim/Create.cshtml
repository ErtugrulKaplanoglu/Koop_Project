@model KooperatifYonetim.Web.Models.VeterinerBakimFormViewModel
@{
    ViewData["Title"] = "Bakım Planla";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">Veteriner Bakımı Planla</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="AhirId" class="form-label fw-semibold"></label>
                        <select asp-for="AhirId" asp-items="Model.AhirListesi" class="form-select">
                            <option value="">— Ahır Seçin —</option>
                        </select>
                        <span asp-validation-for="AhirId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="VeterinerId" class="form-label fw-semibold"></label>
                        <select asp-for="VeterinerId" asp-items="Model.VeterinerListesi" class="form-select">
                            <option value="">— Veteriner Seçin —</option>
                        </select>
                        <span asp-validation-for="VeterinerId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BakimTuru" class="form-label fw-semibold"></label>
                        <select asp-for="BakimTuru"
                                asp-items="Html.GetEnumSelectList<KooperatifYonetim.Core.Enums.BakimTuru>()"
                                class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PlanlananTarih" class="form-label fw-semibold"></label>
                        <input asp-for="PlanlananTarih" type="date" class="form-control"
                               value="@Model.PlanlananTarih.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="PlanlananTarih" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notlar" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notlar" class="form-control" rows="3"
                                  placeholder="Bakım hakkında ek bilgi (opsiyonel)"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-calendar-check me-1"></i> Planla
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
