@model List<KooperatifYonetim.Core.Entities.Mesaj>
@{
    ViewData["Title"] = "Gönderilenler";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="bi bi-send me-2 text-success"></i> Gönderilenler</h4>
        <div class="d-flex gap-2">
            <a asp-action="Inbox" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-inbox me-1"></i> Gelen Kutusu
            </a>
            <a asp-action="YeniMesaj" class="btn btn-primary btn-sm">
                <i class="bi bi-pencil-square me-1"></i> Yeni Mesaj
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-send fs-1 d-block mb-2"></i>
            <p>Henüz mesaj göndermediniz.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Alıcı</th>
                            <th>Konu</th>
                            <th>Tarih</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mesaj in Model)
                        {
                            <tr>
                                <td>@mesaj.Alici.Ad @mesaj.Alici.Soyad</td>
                                <td>
                                    <a asp-action="Detay" asp-route-id="@mesaj.MesajId" class="text-decoration-none text-dark">
                                        @mesaj.Konu
                                    </a>
                                </td>
                                <td class="text-muted small">@mesaj.GonderimTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    @if (mesaj.OkunduMu)
                                    {
                                        <span class="badge bg-success">Okundu</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Okunmadı</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
