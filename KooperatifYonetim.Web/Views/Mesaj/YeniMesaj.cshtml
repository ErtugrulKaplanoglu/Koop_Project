@model KooperatifYonetim.Web.Models.MesajFormViewModel
@{
    ViewData["Title"] = "Yeni Mesaj";
}

<div class="container-fluid py-3">
    <div class="d-flex align-items-center mb-4 gap-2">
        <h4 class="mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i> Yeni Mesaj</h4>
        <a asp-action="Inbox" class="btn btn-outline-secondary btn-sm ms-auto">
            <i class="bi bi-arrow-left me-1"></i> Geri
        </a>
    </div>

    @if (!Model.IzinliAlicilar.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Mesaj gönderebileceğiniz kullanıcı bulunmuyor.
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm" style="max-width:700px">
            <div class="card-body">
                <form asp-action="YeniMesaj" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="AliciId" class="form-label fw-semibold">Alıcı</label>
                        <select asp-for="AliciId" class="form-select">
                            <option value="">-- Alıcı Seçin --</option>
                            @foreach (var kullanici in Model.IzinliAlicilar)
                            {
                                <option value="@kullanici.Id">@kullanici.Ad @kullanici.Soyad (@kullanici.UserName)</option>
                            }
                        </select>
                        <span asp-validation-for="AliciId" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Konu" class="form-label fw-semibold">Konu</label>
                        <input asp-for="Konu" class="form-control" placeholder="Mesaj konusu..." maxlength="200" />
                        <span asp-validation-for="Konu" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Icerik" class="form-label fw-semibold">İçerik</label>
                        <textarea asp-for="Icerik" class="form-control" rows="8" placeholder="Mesajınızı buraya yazın..."></textarea>
                        <span asp-validation-for="Icerik" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send me-1"></i> Gönder
                        </button>
                        <a asp-action="Inbox" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
