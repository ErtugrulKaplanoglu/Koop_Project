@model List<KooperatifYonetim.Core.Entities.Mesaj>
@{
    ViewData["Title"] = "Gelen Kutusu";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="bi bi-inbox me-2 text-primary"></i> Gelen Kutusu</h4>
        <div class="d-flex gap-2">
            <a asp-action="Gonderilenler" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-send me-1"></i> Gönderilenler
            </a>
            <a asp-action="YeniMesaj" class="btn btn-primary btn-sm">
                <i class="bi bi-pencil-square me-1"></i> Yeni Mesaj
            </a>
        </div>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Basari"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            <p>Gelen kutunuzda mesaj bulunmuyor.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th></th>
                            <th>Gönderen</th>
                            <th>Konu</th>
                            <th>Tarih</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mesaj in Model)
                        {
                            <tr class="@(!mesaj.OkunduMu ? "fw-semibold" : "")">
                                <td class="text-center" style="width:30px">
                                    @if (!mesaj.OkunduMu)
                                    {
                                        <i class="bi bi-circle-fill text-primary" style="font-size:0.5rem"></i>
                                    }
                                </td>
                                <td>@mesaj.Gonderen.Ad @mesaj.Gonderen.Soyad</td>
                                <td>
                                    <a asp-action="Detay" asp-route-id="@mesaj.MesajId" class="text-decoration-none text-dark">
                                        @mesaj.Konu
                                    </a>
                                </td>
                                <td class="text-muted small">@mesaj.GonderimTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
