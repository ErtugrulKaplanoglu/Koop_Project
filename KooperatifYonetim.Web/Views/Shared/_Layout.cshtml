<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Kooperatif Yönetim</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg koop-navbar fixed-top shadow-sm">
        <div class="container-fluid">
            <button class="btn btn-link text-white me-2 d-lg-none p-0" id="sidebarToggle">
                <i class="bi bi-list fs-4"></i>
            </button>
            <a class="navbar-brand fw-bold text-white" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-tree-fill me-1"></i> Kooperatif Yönetim
            </a>

            <div class="ms-auto d-flex align-items-center gap-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="badge bg-white text-success fw-semibold">
                        <i class="bi bi-person-badge me-1"></i>
                        @(User.IsInRole("Yonetici") ? "Yönetici" :
                          User.IsInRole("Uretici") ? "Üretici" :
                          User.IsInRole("Veteriner") ? "Veteriner" :
                          User.IsInRole("ZiraatMuhendisi") ? "Ziraat Müh." :
                          User.IsInRole("Toptanci") ? "Toptancı" :
                          User.IsInRole("Mandira") ? "Mandıra" :
                          User.IsInRole("Tedarikci") ? "Tedarikçi" : "Kullanıcı")
                    </span>
                    <span class="text-white-50 small d-none d-md-inline">@User.Identity.Name</span>
                    @await Component.InvokeAsync("MesajZili")
                    @await Component.InvokeAsync("BildirimZili")
                    <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i> Çıkış
                        </button>
                    </form>
                }
            </div>
        </div>
    </nav>

    <div class="d-flex" style="padding-top:56px; min-height:100vh;">

        <!-- SIDEBAR -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <nav id="sidebar" class="koop-sidebar d-flex flex-column">
                <div class="sidebar-content flex-grow-1 py-3">
                    @await Html.PartialAsync("_SidebarMenu")
                </div>
            </nav>
        }

        <!-- ANA İÇERİK -->
        <main class="flex-grow-1 p-4 koop-main @(User.Identity?.IsAuthenticated == true ? "with-sidebar" : "")">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
