@model int
<a asp-controller="Bildirim" asp-action="Index"
   class="position-relative text-white text-decoration-none" title="Bildirimlerim">
    <i class="bi bi-bell fs-5"></i>
    @if (Model > 0)
    {
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
              style="font-size:0.65rem;min-width:1.2rem">
            @(Model > 99 ? "99+" : Model.ToString())
        </span>
    }
</a>
