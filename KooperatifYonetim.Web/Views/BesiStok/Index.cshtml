@model IEnumerable<KooperatifYonetim.Core.Entities.BesiStok>
@{
    ViewData["Title"] = "Besi Yönetimi";
    var kritikSayisi = Model.Count(s => s.MevcutMiktar <= s.EsikMiktar);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Besi Yönetimi</h4>
        <p class="text-muted small mb-0">
            @Model.Count() stok kaydı
            @if (kritikSayisi > 0)
            {
                <span class="badge bg-danger ms-1">@kritikSayisi kritik</span>
            }
        </p>
    </div>
    <a asp-action="Create" class="btn btn-outline-primary">
        <i class="bi bi-plus-circle me-1"></i> Yeni Stok Kaydı
    </a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-archive fs-1 d-block mb-2"></i>
                <span>Besi stoku kaydı bulunmuyor.</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ahır</th>
                            <th>Yem Türü</th>
                            <th>Mevcut</th>
                            <th>Eşik</th>
                            <th>Durum</th>
                            <th>Son Güncelleme</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            var kritik = s.MevcutMiktar <= s.EsikMiktar;
                            var birim = s.YemTuru?.Birim == KooperatifYonetim.Core.Enums.YemBirim.Balya ? "balya" : "çuval";
                            var oran = s.EsikMiktar > 0 ? (int)Math.Min(100, s.MevcutMiktar / s.EsikMiktar * 100) : 100;
                            <tr>
                                <td class="fw-semibold">@s.Ahir?.Ad</td>
                                <td>@s.YemTuru?.Ad</td>
                                <td class="@(kritik ? "text-danger fw-bold" : "")">
                                    @s.MevcutMiktar.ToString("N1") @birim
                                </td>
                                <td class="text-muted">@s.EsikMiktar.ToString("N1") @birim</td>
                                <td style="min-width:140px">
                                    <div class="progress mb-1" style="height:6px">
                                        <div class="progress-bar @(kritik ? "bg-danger" : "bg-success")"
                                             style="width:@oran%"></div>
                                    </div>
                                    @if (kritik)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>Kritik
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                                            <i class="bi bi-check-circle-fill me-1"></i>Normal
                                        </span>
                                    }
                                </td>
                                <td class="text-muted small">@s.SonGuncelleme.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-end">
                                    <a asp-action="StokEkle" asp-route-id="@s.StokId"
                                       class="btn btn-sm btn-success" title="Stok Yükle">
                                        <i class="bi bi-plus-lg"></i>
                                    </a>
                                    <a asp-action="TuketimGir" asp-route-id="@s.StokId"
                                       class="btn btn-sm btn-warning" title="Tüketim Gir">
                                        <i class="bi bi-dash-lg"></i>
                                    </a>
                                    <a asp-action="EsikGuncelle" asp-route-id="@s.StokId"
                                       class="btn btn-sm btn-outline-secondary" title="Eşik Güncelle">
                                        <i class="bi bi-sliders"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@s.StokId"
                                       class="btn btn-sm btn-outline-secondary" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
