@model KooperatifYonetim.Web.Models.BesiStokFormViewModel
@{
    ViewData["Title"] = "Stok Ekle";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">Besi Stoku Ekle</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="AhirId" class="form-label fw-semibold"></label>
                        <select asp-for="AhirId" asp-items="Model.AhirListesi" class="form-select">
                            <option value="">— Ahır Seçin —</option>
                        </select>
                        <span asp-validation-for="AhirId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="YemTuruId" class="form-label fw-semibold"></label>
                        <select asp-for="YemTuruId" asp-items="Model.YemTuruListesi" id="yemTuruSelect" class="form-select">
                            <option value="">— Yem Türü Seçin —</option>
                        </select>
                        <span asp-validation-for="YemTuruId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MevcutMiktar" class="form-label fw-semibold">
                            Mevcut Miktar (<span id="birimLabel">birim</span>)
                        </label>
                        <input asp-for="MevcutMiktar" type="number" step="0.1" class="form-control" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="EsikMiktar" class="form-label fw-semibold">
                            Eşik Miktar (<span id="birimLabel2">birim</span>)
                        </label>
                        <input asp-for="EsikMiktar" type="number" step="0.1" class="form-control" />
                        <div class="form-text">Bu seviyenin altına düşünce kritik uyarısı gösterilir.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-check-circle me-1"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const yemBirimMap = @Html.Raw(ViewBag.YemBirimMap ?? "{}");
        const select = document.getElementById('yemTuruSelect');
        function updateBirim() {
            const birim = yemBirimMap[select.value] || 'birim';
            document.getElementById('birimLabel').textContent = birim;
            document.getElementById('birimLabel2').textContent = birim;
        }
        select.addEventListener('change', updateBirim);
        updateBirim();
    </script>
}
