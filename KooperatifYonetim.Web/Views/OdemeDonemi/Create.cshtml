@model KooperatifYonetim.Web.Models.OdemeDonemiFormViewModel
@{
    ViewData["Title"] = "Yeni Dönem";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">Yeni Ödeme Dönemi</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Yil" class="form-label fw-semibold">Yıl</label>
                        <input asp-for="Yil" type="number" class="form-control" min="2020" max="2100" />
                        <span asp-validation-for="Yil" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Ay" class="form-label fw-semibold">Ay</label>
                        <select asp-for="Ay" class="form-select">
                            @for (int i = 1; i <= 12; i++)
                            {
                                var ayAdi = new DateTime(2000, i, 1).ToString("MMMM");
                                <option value="@i">@ayAdi</option>
                            }
                        </select>
                        <span asp-validation-for="Ay" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-save me-1"></i> Oluştur
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
