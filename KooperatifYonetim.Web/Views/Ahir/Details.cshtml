@model KooperatifYonetim.Core.Entities.Ahir
@{
    ViewData["Title"] = Model.Ad;
    var canEdit = User.IsInRole("Yonetici") || User.IsInRole("Uretici");
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <div>
        <h4 class="fw-bold mb-0">@Model.Ad</h4>
        <p class="text-muted small mb-0">@Model.Uretici?.Ad @Model.Uretici?.Soyad • @Model.HayvanSayisi hayvan</p>
    </div>
    @if (canEdit)
    {
        <a asp-action="Edit" asp-route-id="@Model.AhirId" class="btn btn-outline-secondary ms-auto">
            <i class="bi bi-pencil me-1"></i>Düzenle
        </a>
    }
</div>

<div class="row g-4">

    <!-- Besi Stok -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-archive me-2 text-warning"></i>Besi Stok Durumu</h6>
                @if (canEdit)
                {
                    <a asp-controller="BesiStok" asp-action="Create" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-plus"></i> Stok Ekle
                    </a>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.BesiStoklar.Any())
                {
                    <p class="text-muted small p-3 mb-0">Besi stoku kaydı yok.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Besi Türü</th><th>Mevcut (kg)</th><th>Eşik (kg)</th><th>Son Güncelleme</th></tr></thead>
                        <tbody>
                            @foreach (var s in Model.BesiStoklar)
                            {
                                <tr class="@(s.MevcutMiktar < s.EsikMiktar ? "table-danger" : "")">
                                    <td>@s.BesiTuru</td>
                                    <td>@s.MevcutMiktar.ToString("N1")</td>
                                    <td>@s.EsikMiktar.ToString("N1")</td>
                                    <td class="text-muted small">@s.SonGuncelleme.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Veteriner Bakımları -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-calendar2-heart me-2 text-danger"></i>Veteriner Bakımları</h6>
                @if (canEdit)
                {
                    <a asp-controller="VeterinerBakim" asp-action="Create" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-plus"></i> Planla
                    </a>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.VeterinerBakimlar.Any())
                {
                    <p class="text-muted small p-3 mb-0">Bakım kaydı yok.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Tür</th><th>Planlanan</th><th>Durum</th></tr></thead>
                        <tbody>
                            @foreach (var b in Model.VeterinerBakimlar.OrderBy(x => x.PlanlananTarih).Take(5))
                            {
                                <tr>
                                    <td>@(b.BakimTuru == KooperatifYonetim.Core.Enums.BakimTuru.Acil ? "Acil" : "Periyodik")</td>
                                    <td>@b.PlanlananTarih.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        @if (b.Tamamlandi)
                                        {
                                            <span class="badge bg-success">Tamamlandı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Bekliyor</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Hayvan Hastalık Bildirimleri -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-heart-pulse me-2 text-danger"></i>Hastalık Bildirimleri</h6>
                @if (canEdit)
                {
                    <a asp-controller="HayvanHastalik" asp-action="Create" asp-route-ahirId="@Model.AhirId"
                       class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-plus"></i> Bildirim
                    </a>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.HayvanHastalikBildirimler.Any())
                {
                    <p class="text-muted small p-3 mb-0">Hastalık bildirimi yok.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Tarih</th><th>Veteriner</th><th>Durum</th></tr></thead>
                        <tbody>
                            @foreach (var h in Model.HayvanHastalikBildirimler.OrderByDescending(x => x.BildirimTarihi).Take(5))
                            {
                                <tr>
                                    <td>@h.BildirimTarihi.ToString("dd.MM.yyyy")</td>
                                    <td class="small">@(h.Veteriner is not null ? $"{h.Veteriner.Ad} {h.Veteriner.Soyad}" : "—")</td>
                                    <td>
                                        @switch (h.Durum)
                                        {
                                            case KooperatifYonetim.Core.Enums.BildirimDurum.Beklemede:
                                                <span class="badge bg-warning text-dark">Beklemede</span>
                                                break;
                                            case KooperatifYonetim.Core.Enums.BildirimDurum.Inceleniyor:
                                                <span class="badge bg-primary">İnceleniyor</span>
                                                break;
                                            case KooperatifYonetim.Core.Enums.BildirimDurum.Cozuldu:
                                                <span class="badge bg-success">Çözüldü</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Süt Üretimi -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-droplet me-2 text-info"></i>Son Süt Üretimleri</h6>
                @if (canEdit)
                {
                    <a asp-controller="SutUretimi" asp-action="Create" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-plus"></i> Kayıt Ekle
                    </a>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.SutUretimler.Any())
                {
                    <p class="text-muted small p-3 mb-0">Süt üretimi kaydı yok.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Tarih</th><th>Mandira</th><th>Miktar (L)</th></tr></thead>
                        <tbody>
                            @foreach (var s in Model.SutUretimler.OrderByDescending(x => x.Tarih).Take(5))
                            {
                                <tr>
                                    <td>@s.Tarih.ToString("dd.MM.yyyy")</td>
                                    <td class="small">@s.Mandira?.Ad @s.Mandira?.Soyad</td>
                                    <td>@s.Miktar.ToString("N1")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>
