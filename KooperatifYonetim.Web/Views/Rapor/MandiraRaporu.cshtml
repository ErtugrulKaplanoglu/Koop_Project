@model KooperatifYonetim.Web.Models.MandiraRaporuViewModel
@{
    ViewData["Title"] = "Süt Raporları";
    var ayAdlari = new[] { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran",
                           "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };
    var buYil = DateTime.Today.Year;
    var gunler = Model.GunlukSutler.Select(g => g.Tarih.Day.ToString()).ToList();
    var miktarlar = Model.GunlukSutler.Select(g => g.Miktar).ToList();
}

<div class="container-fluid py-3">
    <div class="d-flex align-items-center mb-4 gap-3">
        <h4 class="mb-0"><i class="bi bi-droplet me-2 text-primary"></i> Süt Raporları</h4>
        <span class="badge bg-primary fs-6">@ayAdlari[Model.Ay] @Model.Yil</span>
    </div>

    <form method="get" class="card mb-4 border-0 shadow-sm">
        <div class="card-body d-flex gap-3 align-items-end flex-wrap">
            <div>
                <label class="form-label fw-semibold">Yıl</label>
                <select name="yil" class="form-select" style="width:100px">
                    @for (int y = buYil; y >= buYil - 3; y--)
                    {
                        <option value="@y" selected="@(Model.Yil == y)">@y</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label fw-semibold">Ay</label>
                <select name="ay" class="form-select" style="width:130px">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(Model.Ay == m)">@ayAdlari[m]</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i> Getir
            </button>
        </div>
    </form>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-primary">@Model.ToplamSut.ToString("N1")</div>
                    <div class="text-muted mt-1"><i class="bi bi-droplet me-1"></i> Aylık Toplam (lt)</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    @{
                        var ortalama = Model.GunlukSutler.Count > 0
                            ? Model.ToplamSut / Model.GunlukSutler.Count
                            : 0m;
                    }
                    <div class="display-6 fw-bold text-success">@ortalama.ToString("N1")</div>
                    <div class="text-muted mt-1"><i class="bi bi-graph-up me-1"></i> Günlük Ortalama (lt)</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-info">@Model.GunlukSutler.Count</div>
                    <div class="text-muted mt-1"><i class="bi bi-calendar-check me-1"></i> Kayıt Günü</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.GunlukSutler.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="bi bi-graph-up me-2 text-primary"></i> Günlük Süt Üretimi</h6>
            </div>
            <div class="card-body">
                <canvas id="sutChart" height="100"></canvas>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="bi bi-table me-2 text-primary"></i> Günlük Detay</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th class="text-end">Miktar (lt)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kayit in Model.GunlukSutler)
                        {
                            <tr>
                                <td>@kayit.Tarih.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</td>
                                <td class="text-end fw-semibold">@kayit.Miktar.ToString("N1")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th>Toplam</th>
                            <th class="text-end">@Model.ToplamSut.ToString("N1") lt</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-droplet fs-1 d-block mb-2"></i>
            <p>@ayAdlari[Model.Ay] @Model.Yil dönemine ait süt kaydı bulunamadı.</p>
        </div>
    }
</div>

@section Scripts {
@if (Model.GunlukSutler.Count > 0)
{
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    new Chart(document.getElementById('sutChart'), {
        type: 'line',
        data: {
            labels: [@Html.Raw(string.Join(",", gunler.Select(g => $"'{g}'")))],
            datasets: [{
                label: 'Süt (lt)',
                data: [@string.Join(",", miktarlar.Select(m => m.ToString(System.Globalization.CultureInfo.InvariantCulture)))],
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13,110,253,0.1)',
                tension: 0.3,
                fill: true,
                pointRadius: 4
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });
</script>
}
}
