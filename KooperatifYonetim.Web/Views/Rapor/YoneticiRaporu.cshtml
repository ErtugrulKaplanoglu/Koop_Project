@model KooperatifYonetim.Web.Models.YoneticiRaporuViewModel
@{
    ViewData["Title"] = "Üretici Raporları";
    var ayAdlari = new[] { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran",
                           "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };
    var buYil = DateTime.Today.Year;
    var adlar = Model.Satirlar.Select(s => s.UreticiAdi).ToList();
    var hasatlar = Model.Satirlar.Select(s => s.ToplamHasatKg).ToList();
    var sutler = Model.Satirlar.Select(s => s.ToplamSutLitre).ToList();
}

<div class="container-fluid py-3">
    <div class="d-flex align-items-center mb-4 gap-3">
        <h4 class="mb-0"><i class="bi bi-bar-chart-line me-2 text-success"></i> Üretici Raporları</h4>
        <span class="badge bg-success fs-6">@ayAdlari[Model.Ay] @Model.Yil</span>
    </div>

    <form method="get" class="card mb-4 border-0 shadow-sm">
        <div class="card-body d-flex gap-3 align-items-end flex-wrap">
            <div>
                <label class="form-label fw-semibold">Yıl</label>
                <select name="yil" class="form-select" style="width:100px">
                    @for (int y = buYil; y >= buYil - 3; y--)
                    {
                        <option value="@y" selected="@(Model.Yil == y)">@y</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label fw-semibold">Ay</label>
                <select name="ay" class="form-select" style="width:130px">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(Model.Ay == m)">@ayAdlari[m]</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-search me-1"></i> Getir
            </button>
        </div>
    </form>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-success">@Model.ToplamHasatKg.ToString("N1")</div>
                    <div class="text-muted mt-1"><i class="bi bi-bag-check me-1"></i> Toplam Hasat (kg)</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-primary">@Model.ToplamSutLitre.ToString("N1")</div>
                    <div class="text-muted mt-1"><i class="bi bi-droplet me-1"></i> Toplam Süt (lt)</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-warning">@Model.ToplamOdeme.ToString("N2") ₺</div>
                    <div class="text-muted mt-1"><i class="bi bi-cash-coin me-1"></i> Toplam Ödeme</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Satirlar.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2 text-success"></i> Hasat ve Süt Karşılaştırması</h6>
            </div>
            <div class="card-body">
                <canvas id="ureticiChart" height="120"></canvas>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="bi bi-table me-2 text-success"></i> Üretici Detayı</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Üretici</th>
                            <th class="text-end">Hasat (kg)</th>
                            <th class="text-end">Süt (lt)</th>
                            <th class="text-end">Ödeme (₺)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var satir in Model.Satirlar)
                        {
                            <tr>
                                <td>@satir.UreticiAdi</td>
                                <td class="text-end">@satir.ToplamHasatKg.ToString("N1")</td>
                                <td class="text-end">@satir.ToplamSutLitre.ToString("N1")</td>
                                <td class="text-end fw-semibold @(satir.ToplamOdeme > 0 ? "text-success" : "text-muted")">
                                    @satir.ToplamOdeme.ToString("N2") ₺
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th>Toplam</th>
                            <th class="text-end">@Model.ToplamHasatKg.ToString("N1") kg</th>
                            <th class="text-end">@Model.ToplamSutLitre.ToString("N1") lt</th>
                            <th class="text-end">@Model.ToplamOdeme.ToString("N2") ₺</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bar-chart-line fs-1 d-block mb-2"></i>
            <p>@ayAdlari[Model.Ay] @Model.Yil dönemine ait üretici verisi bulunamadı.</p>
        </div>
    }
</div>

@section Scripts {
@if (Model.Satirlar.Count > 0)
{
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    new Chart(document.getElementById('ureticiChart'), {
        type: 'bar',
        data: {
            labels: [@Html.Raw(string.Join(",", adlar.Select(a => $"'{a}'")))],
            datasets: [
                {
                    label: 'Hasat (kg)',
                    data: [@string.Join(",", hasatlar.Select(h => h.ToString(System.Globalization.CultureInfo.InvariantCulture)))],
                    backgroundColor: 'rgba(25,135,84,0.7)',
                    borderColor: '#198754',
                    borderWidth: 1
                },
                {
                    label: 'Süt (lt)',
                    data: [@string.Join(",", sutler.Select(s => s.ToString(System.Globalization.CultureInfo.InvariantCulture)))],
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderColor: '#0d6efd',
                    borderWidth: 1
                }
            ]
        },
        options: {
            responsive: true,
            scales: { y: { beginAtZero: true } }
        }
    });
</script>
}
}
