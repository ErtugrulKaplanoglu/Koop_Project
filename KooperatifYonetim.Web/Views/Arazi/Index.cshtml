@model IEnumerable<KooperatifYonetim.Core.Entities.Arazi>
@{
    ViewData["Title"] = "Araziler";
    var canCreate = User.IsInRole("Yonetici");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Araziler</h4>
        <p class="text-muted small mb-0">Toplam @Model.Count() arazi</p>
    </div>
    @if (canCreate)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Yeni Arazi
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-map fs-1 d-block mb-2"></i>
                Henüz arazi eklenmemiş.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Arazi Adı</th>
                            <th>Yüz Ölçümü</th>
                            <th>Konum</th>
                            <th>Ekin Sayısı</th>
                            <th>Durum</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var arazi in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@arazi.Ad</td>
                                <td>@arazi.YuzOlcumu dönüm</td>
                                <td class="text-muted small">@arazi.Enlem.ToString("F4"), @arazi.Boylam.ToString("F4")</td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary">@arazi.Ekinler.Count ekin</span>
                                </td>
                                <td>
                                    @if (arazi.AktifMi)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@arazi.AraziId" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Yonetici") || arazi.UreticiId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                    {
                                        <a asp-action="Edit" asp-route-id="@arazi.AraziId" class="btn btn-sm btn-outline-primary ms-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@arazi.AraziId" method="post" class="d-inline ms-1"
                                              onsubmit="return confirm('@arazi.Ad arazisini silmek istediğinizden emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
