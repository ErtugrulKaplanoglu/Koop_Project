@model KooperatifYonetim.Web.Models.SutUretimiFormViewModel
@{
    ViewData["Title"] = "Süt Üretimi Kaydet";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">Süt Üretimi Kaydı Ekle</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="AhirId" class="form-label fw-semibold"></label>
                        <select asp-for="AhirId" asp-items="Model.AhirListesi" class="form-select">
                            <option value="">— Ahır Seçin —</option>
                        </select>
                        <span asp-validation-for="AhirId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MandiraId" class="form-label fw-semibold"></label>
                        <select asp-for="MandiraId" asp-items="Model.MandiraListesi" class="form-select">
                            <option value="">— Mandira Seçin —</option>
                        </select>
                        <span asp-validation-for="MandiraId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Miktar" class="form-label fw-semibold"></label>
                        <input asp-for="Miktar" type="number" step="0.1" class="form-control" />
                        <span asp-validation-for="Miktar" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Tarih" class="form-label fw-semibold"></label>
                        <input asp-for="Tarih" type="date" class="form-control"
                               value="@Model.Tarih.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-check-circle me-1"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
