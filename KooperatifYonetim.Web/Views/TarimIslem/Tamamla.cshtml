@model KooperatifYonetim.Web.Models.TamamlaViewModel
@{
    ViewData["Title"] = "İşlemi Tamamla";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">İşlemi Tamamlandı Olarak İşaretle</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm border-start border-success border-3">
            <div class="card-body">
                <div class="mb-3 p-3 bg-light rounded-3">
                    <div class="text-muted small">İşlem Türü</div>
                    <div class="fw-bold">@Model.IslemTuruAdi</div>
                    <div class="text-muted small mt-1">Planlanan: @Model.PlanlananTarih.ToString("dd.MM.yyyy")</div>
                </div>

                <form asp-action="Tamamla" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IslemId" type="hidden" />
                    <input asp-for="IslemTuruAdi" type="hidden" />
                    <input asp-for="PlanlananTarih" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="GerceklesenTarih" class="form-label fw-semibold"></label>
                        <input asp-for="GerceklesenTarih" class="form-control" type="date" />
                        <span asp-validation-for="GerceklesenTarih" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Miktar" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Miktar" class="form-control" placeholder="Opsiyonel" />
                            <span class="input-group-text">kg / lt</span>
                        </div>
                        <div class="form-text">Sulama için litre, toplama için kg giriniz.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-success flex-fill">
                            <i class="bi bi-check-circle me-1"></i> Tamamlandı İşaretle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
