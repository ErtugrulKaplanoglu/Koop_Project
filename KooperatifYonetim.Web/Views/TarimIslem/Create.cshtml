@model KooperatifYonetim.Web.Models.TarimIslemFormViewModel
@{
    ViewData["Title"] = "Yeni Tarım İşlemi";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
    <h4 class="fw-bold mb-0">Yeni Tarım İşlemi</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="EkinId" class="form-label fw-semibold"></label>
                        <select asp-for="EkinId" asp-items="Model.EkinListesi" class="form-select">
                            <option value="">— Ekin Seçin —</option>
                        </select>
                        <span asp-validation-for="EkinId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IslemTuru" class="form-label fw-semibold"></label>
                        <select asp-for="IslemTuru" asp-items="Html.GetEnumSelectList<KooperatifYonetim.Core.Enums.IslemTuru>()" class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PlanlananTarih" class="form-label fw-semibold"></label>
                        <input asp-for="PlanlananTarih" class="form-control" type="date" />
                        <span asp-validation-for="PlanlananTarih" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Miktar" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Miktar" class="form-control" placeholder="Opsiyonel" />
                            <span class="input-group-text">kg / lt</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notlar" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notlar" class="form-control" rows="2" placeholder="Opsiyonel not"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">İptal</a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-save me-1"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
