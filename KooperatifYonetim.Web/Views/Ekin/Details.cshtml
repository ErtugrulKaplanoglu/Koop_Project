@model KooperatifYonetim.Core.Entities.Ekin
@{
    ViewData["Title"] = Model.EkinTuru;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-controller="Arazi" asp-action="Details" asp-route-id="@Model.AraziId" class="btn btn-sm btn-outline-secondary me-2">
            <i class="bi bi-arrow-left"></i> Araziye Dön
        </a>
        <span class="fw-bold fs-5">@Model.EkinTuru</span>
        @switch (Model.Durum)
        {
            case KooperatifYonetim.Core.Enums.EkinDurum.Aktif:
                <span class="badge bg-success ms-2">Aktif</span>
                break;
            case KooperatifYonetim.Core.Enums.EkinDurum.HasatAsamasi:
                <span class="badge bg-warning text-dark ms-2">Hasat Aşaması</span>
                break;
            case KooperatifYonetim.Core.Enums.EkinDurum.Tamamlandi:
                <span class="badge bg-secondary ms-2">Tamamlandı</span>
                break;
        }
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.EkinId" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil me-1"></i> Düzenle
        </a>
        <form asp-action="Delete" asp-route-id="@Model.EkinId" method="post"
              onsubmit="return confirm('Bu ekini silmek istediğinizden emin misiniz?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash me-1"></i> Sil
            </button>
        </form>
    </div>
</div>

<!-- Ekin Bilgileri -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-info-circle me-2 text-primary"></i>Ekin Bilgileri</h6>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted small">Arazi</dt>
                    <dd class="col-7">
                        <a asp-controller="Arazi" asp-action="Details" asp-route-id="@Model.AraziId">
                            @Model.Arazi?.Ad
                        </a>
                    </dd>
                    <dt class="col-5 text-muted small">Üretici</dt>
                    <dd class="col-7">@Model.Arazi?.Uretici?.Ad @Model.Arazi?.Uretici?.Soyad</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted small">Ekim Tarihi</dt>
                    <dd class="col-7">@Model.EkimTarihi.ToString("dd.MM.yyyy")</dd>
                    <dt class="col-5 text-muted small">Hasat Tarihi</dt>
                    <dd class="col-7">@(Model.HasatTarihi?.ToString("dd.MM.yyyy") ?? "Belirtilmedi")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<!-- Tarım İşlemleri -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0"><i class="bi bi-calendar-check me-2 text-success"></i>Tarım İşlemleri</h6>
        <a asp-controller="TarimIslem" asp-action="Create" asp-route-ekinId="@Model.EkinId" class="btn btn-sm btn-outline-success">
            <i class="bi bi-plus-circle me-1"></i> İşlem Ekle
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.TarimIslemler.Any())
        {
            <p class="text-muted small px-3 py-3 mb-0">Bu ekin için henüz işlem eklenmemiş.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>İşlem Türü</th>
                            <th>Planlanan Tarih</th>
                            <th>Gerçekleşen</th>
                            <th>Miktar</th>
                            <th>Durum</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var islem in Model.TarimIslemler.OrderBy(i => i.PlanlananTarih))
                        {
                            <tr class="@(islem.Tamamlandi ? "table-light" : "")">
                                <td>
                                    @switch (islem.IslemTuru)
                                    {
                                        case KooperatifYonetim.Core.Enums.IslemTuru.Sulama:
                                            <i class="bi bi-droplet text-primary me-1"></i>
                                            break;
                                        case KooperatifYonetim.Core.Enums.IslemTuru.Ilacalama:
                                            <i class="bi bi-bug text-danger me-1"></i>
                                            break;
                                        case KooperatifYonetim.Core.Enums.IslemTuru.Toplama:
                                            <i class="bi bi-basket text-success me-1"></i>
                                            break;
                                    }
                                    @islem.IslemTuru
                                </td>
                                <td>@islem.PlanlananTarih.ToString("dd.MM.yyyy")</td>
                                <td>@(islem.GerceklesenTarih?.ToString("dd.MM.yyyy") ?? "—")</td>
                                <td>@(islem.Miktar.HasValue ? $"{islem.Miktar} kg/lt" : "—")</td>
                                <td>
                                    @if (islem.Tamamlandi)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check me-1"></i>Tamamlandı</span>
                                    }
                                    else if (islem.PlanlananTarih < DateTime.Today)
                                    {
                                        <span class="badge bg-danger">Gecikmiş</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Bekliyor</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (!islem.Tamamlandi)
                                    {
                                        <a asp-controller="TarimIslem" asp-action="Tamamla" asp-route-id="@islem.IslemId"
                                           class="btn btn-sm btn-outline-success" title="Tamamla">
                                            <i class="bi bi-check-circle"></i>
                                        </a>
                                    }
                                    <a asp-controller="TarimIslem" asp-action="Edit" asp-route-id="@islem.IslemId"
                                       class="btn btn-sm btn-outline-primary ms-1" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="TarimIslem" asp-action="Delete" asp-route-id="@islem.IslemId"
                                          method="post" class="d-inline ms-1"
                                          onsubmit="return confirm('Bu işlemi silmek istediğinizden emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Hastalık Bildirimleri -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0"><i class="bi bi-bug me-2 text-danger"></i>Hastalık Bildirimleri</h6>
        <a asp-controller="TarimHastalik" asp-action="Create" asp-route-ekinId="@Model.EkinId" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-plus-circle me-1"></i> Bildirim Ekle
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.HastalıkBildirimler.Any())
        {
            <p class="text-muted small px-3 py-3 mb-0">Hastalık bildirimi bulunmuyor.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Açıklama</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.HastalıkBildirimler.OrderByDescending(x => x.BildirimTarihi))
                        {
                            <tr>
                                <td>@b.BildirimTarihi.ToString("dd.MM.yyyy")</td>
                                <td>@b.Aciklama</td>
                                <td>
                                    @switch (b.Durum)
                                    {
                                        case KooperatifYonetim.Core.Enums.BildirimDurum.Beklemede:
                                            <span class="badge bg-warning text-dark">Beklemede</span>
                                            break;
                                        case KooperatifYonetim.Core.Enums.BildirimDurum.Inceleniyor:
                                            <span class="badge bg-primary">İnceleniyor</span>
                                            break;
                                        case KooperatifYonetim.Core.Enums.BildirimDurum.Cozuldu:
                                            <span class="badge bg-success">Çözüldü</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
